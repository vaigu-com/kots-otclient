    VerticalSeparator
      id: separator
      anchors.top: parent.top
      anchors.left: prev.right
      margin-left: 4
      margin-top: 1
      height: 24

    Panel
      height: 24
      id: cooldownPanel
      margin-top: 1
      margin-bottom: 3
      anchors.top: parent.top
      anchors.bottom: parent.bottom
      anchors.left: prev.right
      anchors.right: parent.right
      margin-left: 4
      layout:
        type: horizontalBox
        spacing: 3
