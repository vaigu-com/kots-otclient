SpellGroupIcon < UIWidget
  size: 20 20
  image-size: 20 20
  image-source: /images/game/spells/spellgroup-icons-20x20
  focusable: false
  image-color: #4B4B4B
  $on:
    image-color: #FFFFFF

SpellIcon < UIWidget
  size: 20 20
  image-size: 20 20
  focusable: false

SpellProgressRect < UIProgressRect
  percent: 100
  show-progress: false
  focusable: false

SpellIconContainer < UIWidget
  size: 22 24
  image-source: /images/game/cooldowns/cooldown-background
  image-size: 22 24
  focusable: false

GroupCooldownParticles < UIParticles
  effect: groupcooldown-effect

Panel
  id: cooldownWindow
  !text: tr('')
  size: 220 32
  anchors.top: parent.top
  anchors.left: parent.left
  anchors.right: parent.right
  focusable: false
  phantom: true
  Panel
    id: contentsPanel2
    anchors.fill: parent
    margin-left: 1

    UIWidget
      id: containerAttack
      size: 22 24
      image-source: /images/game/cooldowns/cooldown-background
      image-size: 22 24
      focusable: false
      anchors.top: parent.top
      anchors.left: parent.left
      margin-left: 2
      margin-top: 1

      SpellGroupIcon
        id: icon
        image-clip: 0 0 20 20
        anchors.top: parent.top
        anchors.left: parent.left
        margin-top: 1
        margin-left: 1

      UIWidget
        id: cooldownBarBg
        size: 20 2
        background-color: #000000
        anchors.top: icon.bottom
        anchors.left: parent.left
        margin-top: 1
        margin-left: 1
        focusable: false

      UIWidget
        id: cooldownBarFg
        size: 0 2
        background-color: #FFFFFF
        anchors.top: icon.bottom
        anchors.left: parent.left
        margin-top: 1
        margin-left: 1
        focusable: false

      SpellProgressRect
        id: progressRect
        anchors.fill: parent
        !tooltip: tr('Attack')

    UIWidget
      id: containerHealing
      size: 22 24
      image-source: /images/game/cooldowns/cooldown-background
      image-size: 22 24
      focusable: false
      anchors.top: parent.top
      anchors.left: containerAttack.right
      margin-left: 4
      margin-top: 1

      SpellGroupIcon
        id: icon
        image-clip: 20 0 20 20
        anchors.top: parent.top
        anchors.left: parent.left
        margin-top: 1
        margin-left: 1

      UIWidget
        id: cooldownBarBg
        size: 20 2
        background-color: #000000
        anchors.top: icon.bottom
        anchors.left: parent.left
        margin-top: 1
        margin-left: 1
        focusable: false

      UIWidget
        id: cooldownBarFg
        size: 0 2
        background-color: #FFFFFF
        anchors.top: icon.bottom
        anchors.left: parent.left
        margin-top: 1
        margin-left: 1
        focusable: false

      SpellProgressRect
        id: progressRect
        anchors.fill: parent
        !tooltip: tr('Healing')

